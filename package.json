{
  "name": "afm-ai",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c blue,magenta \"npm run dev:web\" \"npm run dev:server\"",
    "dev:web": "next dev --turbopack",
    "dev:server": "npm run dev -w @afm/server",
    "prebuild": "node -e \"const p=require('./package.json');if(!p.dependencies?.next){console.error('ERROR: next must be in root package.json. Set Vercel Root Directory to the repo root (empty), not a workspace subfolder.');process.exit(1)}\"",
    "build": "npm run build -w @afm/ai-core && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "npm run generate -w @afm/db",
    "db:push": "npm run push -w @afm/db",
    "db:studio": "npm run studio -w @afm/db"
  },
  "dependencies": {
    "@afm/ai-core": "workspace:*",
    "@afm/db": "workspace:*",
    "@clerk/nextjs": "^6.12.0",
    "@google/genai": "^2.4.0",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@supabase/supabase-js": "^2.49.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.4.7",
    "jspdf": "^2.5.2",
    "lucide-react": "^0.475.0",
    "next": "^15.2.0",
    "next-themes": "^0.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^17.7.0",
    "svix": "^1.61.0",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "eslint": "^9",
    "eslint-config-next": "^15.2.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
