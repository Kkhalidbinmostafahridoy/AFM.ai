# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AFM Backend API (apps/server) — frontend NEVER calls OpenAI/Gemini directly
AFM_API_URL=http://127.0.0.1:4000
AFM_SERVER_PORT=4000
NEXT_PUBLIC_AFM_WS_URL=ws://127.0.0.1:4000
AFM_CORS_ORIGIN=http://localhost:3000

# PostgreSQL (AFM Memory / analytics persistence)
# Leave empty until DB exists — avoids Prisma errors. Create DB then run: npm run db:push
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/afm_ai
DATABASE_URL=

# Redis (Phase 2 — queues, cache, pub/sub, analytics)
# REDIS_URL=redis://127.0.0.1:6379

# Analytics (enterprise telemetry)
# ANALYTICS_ENCRYPTION_KEY=   # optional at-rest encryption for aggregated exports

# Anthropic Claude
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Media (Phase 2+)
# ELEVENLABS_API_KEY=
# RUNWAY_API_KEY=
# STABILITY_API_KEY=

# Research (Phase 2)
# TAVILY_API_KEY=
# SERPER_API_KEY=

# AFM.ai branding (optional)
# AI_ASSISTANT_NAME=AFM.ai
# NEXT_PUBLIC_AI_ASSISTANT_NAME=AFM.ai

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_bG95YWwtYWlyZWRhbGUtOTEuY2xlcmsuYWNjb3VudHMuZGV2JA
CLERK_SECRET_KEY=sk_test_XH7FUkg8QAmyHrW0MLl9qSy1mgm7accYA31V6pEMTx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
CLERK_WEBHOOK_SECRET=whsec_xxx

# Supabase — https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# anon public key (dashboard may call this SUPABASE_KEY in their snippet)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_KEY=              # optional alias for anon key (same value as above)
# service_role secret (server only — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini (AI Studio) — https://aistudio.google.com/apikey
# Required for all AI features. Do NOT use OpenAI/OpenCode keys here.
GEMINI_API_KEY=
# Optional aliases (also supported): GOOGLE_API_KEY, GOOGLE_GENAI_API_KEY
# Optional model overrides (defaults are sensible for the Gemini API)
# GEMINI_TEXT_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=imagen-4.0-generate-001
# GEMINI_IMAGE_EDIT_MODEL=imagen-3.0-capability-001
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# PIPELINE_MAX_SCENES=2
# PIPELINE_SCENE_DELAY_MS=2000
# GEMINI_CHAT_MODEL=gemini-2.5-flash-lite
# PIPELINE_MAX_SCENES=4
# Do NOT set GEMINI_* models to OpenAI model names (e.g. gpt-4o) — use gemini-* only

# --- Multi-model AI Chat (optional — add any combination) ---
# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek — https://platform.deepseek.com
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat

# Grok (xAI) — https://console.x.ai
# XAI_API_KEY=
# GROK_API_KEY=
# GROK_MODEL=grok-2-latest

# OpenCode (OpenAI-compatible server you host or vendor provides)
# OPENCODE_API_KEY=
# OPENCODE_BASE_URL=https://your-opencode-host/v1
# OPENCODE_MODEL=default

# Generic cloud / OpenAI-compatible inference
# CLOUD_AI_API_KEY=
# CLOUD_AI_BASE_URL=https://your-inference-endpoint/v1
# CLOUD_AI_MODEL=default

# CHAT_ENABLE_FUSION=1

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PREMIUM_PRICE_ID=price_xxx
